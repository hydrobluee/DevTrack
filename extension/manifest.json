{
  "manifest_version": 3,
  "name": "DevTrack",
  "description": "Quickly view upcoming programming contests and launch the DevTrack dashboard from your browser toolbar.",
  "version": "0.1.0",
  "icons": {
    "128": "icon128.png"
  },
  "permissions": ["storage", "tabs", "scripting"],
  "host_permissions": [
    "http://localhost:3000/*",
    "https://leetcode.com/*",
    "https://*/*",
    "http://*/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://leetcode.com/*"],
      "js": ["content.js"],
      "run_at": "document_end",
      "all_frames": false
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}
